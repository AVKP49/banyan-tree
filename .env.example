# Google Gemini Flash API key (free at aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Groq fallback LLM (free at console.groq.com)
GROQ_API_KEY=

# Cloudflare R2 public URL for audio/artwork assets
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Rate limit for Ask Dadi (requests per device per hour)
RATE_LIMIT_PER_HOUR=30

# Environment
ENVIRONMENT=development

# Supabase (Phase 1+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Phase 1+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Client-side
VITE_PUBLIC_API_BASE=http://localhost:8787
